{
  "name": "autonomous-web-research-agent",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:api",
    "dev:api": "npm run dev -w @autonomous/api",
    "dev:web": "npm run dev -w @autonomous/web",
    "build:types": "npm run build -w @autonomous/types",
    "build:api": "npm run build:types && npm run build -w @autonomous/api",
    "build:web": "npm run build -w @autonomous/web"
  },
  "devDependencies": {
    "@express-rate-limit/tsconfig": "^1.0.2"
  }
}
